# Build: cp frontEND/.env.production.example frontEND/.env.production
# Sonra: npm run build

# Variant A — tam URL (başqa subdomain və s.)
# VITE_API_BASE_URL=https://api.sizin-domain.com

# Variant B — eyni domen, Nginx /api/v1 → backend (sorğu brauzerdən həmin domenə gedir)
VITE_API_BASE_URL=/api/v1
