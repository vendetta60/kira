# Lokal: layihə kökündən .\dev.ps1 — əvvəl API (8001), sonra Vite (proxy ECONNREFUSED olmaz).
# Əgər yalnız "npm run dev" işlədirsənsə, ayrıca terminalda .\run-backend.ps1 işlədin.

# npm run dev + Vite proxy:
VITE_API_BASE_URL=/api/v1
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8001

# Proxy olmadan (brauzer birbaşa API-yə gedir; CORS backenddə * olmalıdır):
# VITE_API_BASE_URL=http://127.0.0.1:8001
