APP_NAME=Kirayə müqavilələrinin elektron qeydiyyatı
ENV=dev

# MSSQL — tam URL (tövsiyə olunur)
DATABASE_URL=mssql+pyodbc://sa:123@555-PTSAKTB-Z\SQLEXPRESS/Rently?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes

# DATABASE_URL boşdursa:
# DB_SERVER=555-PTSAKTB-Z\SQLEXPRESS
# DB_NAME=Rently
# DB_USER=sa
# DB_PASSWORD=123
# DB_DRIVER=ODBC Driver 17 for SQL Server
# DB_TRUST_SERVER_CERT=yes

JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_MINUTES=10080

CORS_ALLOW_ORIGINS=*

# Nginx brauzerdə /api/v1 prefiksini kəsib backend-ə kök yollar ötürürsə → ROOT_PATH boş saxlayın.
# ROOT_PATH yalnız reverse proxy prefiksi KESILMEDEN oturulduqda lazımdır (bu layihənin nginx.example.conf-u prefiksi kəsir).

# Uvicorn — systemd rently-api.service bu dəyərləri oxuyur (ayrıca Python skripti yoxdur)
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8001
UVICORN_WORKERS=1

# İlk işə düşmə: Users boşdursa
BOOTSTRAP_SUPERADMIN_ENABLED=true
BOOTSTRAP_SUPERADMIN_USERNAME=superadmin45
BOOTSTRAP_SUPERADMIN_PASSWORD=admin123
BOOTSTRAP_SUPERADMIN_FULL_NAME=System Super Admin

BOOTSTRAP_ADMIN_USERNAME=admin45
BOOTSTRAP_ADMIN_PASSWORD=admin123
BOOTSTRAP_ADMIN_FULL_NAME=System Admin
